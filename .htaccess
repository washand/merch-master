Options -Indexes
DirectoryIndex index.php index.html

# Verberg .php extensie — /faq werkt als /faq.php
RewriteEngine On
# ── URL rewriting — geen .php extensie nodig ──────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^dtf/?$           dtf.php           [L]
RewriteRule ^zeefdruk/?$      zeefdruk.php      [L]
RewriteRule ^borduren/?$      borduren.php      [L]
RewriteRule ^over-ons/?$      over-ons.php      [L]
RewriteRule ^faq/?$           faq.php           [L]
RewriteRule ^contact/?$       contact.php       [L]
RewriteRule ^bestellen/?$     bestellen.php     [L]
RewriteRule ^bestellen-oud/?$ bestellen-oud.php [L]
RewriteRule ^duurzaam/?$      duurzaam.php      [L]
RewriteRule ^portaal/?$       portaal.php       [L]
RewriteRule ^privacy/?$       privacy.php       [L]
RewriteRule ^voorwaarden/?$   voorwaarden.php   [L]
RewriteRule ^verzendkosten/?$ verzendkosten.php [L]
RewriteRule ^admin/?$         admin.php         [L,NC]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# Redirect .html naar .php
RewriteCond %{THE_REQUEST} \.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Cache afbeeldingen
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
  Header set Cache-Control "max-age=2592000, public"
</FilesMatch>

# Gzip compressie
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

# 404 pagina
ErrorDocument 404 /404.php
